LLM_PROVIDER="openai_compatible"
LLM_API_KEY="your_api_key_here"
LLM_BASE_URL="https://your-endpoint/v1"
LLM_CHAT_MODEL="your-chat-model"
LLM_EMBEDDING_MODEL="your-embedding-model"

# Optional tuning
LLM_REQUEST_TIMEOUT="35"
LLM_MAX_RETRIES="3"
LLM_RETRY_MAX_DELAY="8"

# Optional dedicated embedding provider
# LLM_EMBEDDING_PROVIDER="openai_compatible"
# LLM_EMBEDDING_API_KEY="your_embedding_api_key_here"
# LLM_EMBEDDING_BASE_URL="https://your-embedding-endpoint/v1"
# LLM_EMBEDDING_MODEL="your-embedding-model"
